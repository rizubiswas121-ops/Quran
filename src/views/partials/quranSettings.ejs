      </div>

      <div class="sp-section">
        <label class="sp-label">Custom Audio Directory</label>
        <input type="text" class="form-control form-control-sm" id="customAudioDir" placeholder="https://your-server.com/audio/">
        <small class="text-muted">Format: {surah}{ayah}.mp3</small>
      </div>

      <div class="sp-section">
        <a href="#" class="qns-link" data-bs-toggle="modal" data-bs-target="#helpModal">
          <i class="bi bi-question-circle-fill"></i>
          <span>Help & Support</span>
        </a>
      </div>
    </div>
  </div>
</aside>
