<!-- Left Navigation Sidebar -->
<aside class="quran-nav-sidebar" id="quranNavSidebar">
  <div class="qns-header">
    <a href="/" class="qns-logo">
      <div class="logo-box"><span class="logo-text">ত</span></div>
      <div class="brand-text-container">
        <span class="brand-main-text">TazqiaNafs</span>
        <span class="brand-sub-text">আত্মশুদ্ধির পথে</span>
      </div>
    </a>
    <button class="qns-close" id="quranNavClose"><i class="bi bi-x-lg"></i></button>
  </div>

  <div class="qns-body">
    <!-- Jump to Verse -->
    <div class="qns-section">
      <h6 class="qns-section-title"><i class="bi bi-signpost-split-fill me-2"></i>Jump to Verse</h6>
      <div class="qns-jump-form">
        <select class="form-select form-select-sm mb-2" id="jumpSurahSelect">
          <option value="">Select Surah</option>
          <% if (typeof surahs !== 'undefined') { %>
            <% surahs.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.id %>. <%= s.transliteration %> (<%= s.banglish || s.name %>)</option>
            <% }) %>
          <% } %>
        </select>
        <div class="d-flex gap-2 mb-2">
          <select class="form-select form-select-sm" id="jumpAyahSelect" disabled>
            <option value="">Ayah</option>
          </select>
          <select class="form-select form-select-sm" id="jumpPageSelect" disabled>
            <option value="">Page</option>
          </select>
        </div>
        <button class="btn btn-success btn-sm w-100 fw-bold" id="jumpGoBtn" disabled>
          <i class="bi bi-arrow-right-circle me-1"></i>Go to Surah
        </button>
      </div>
    </div>

    <!-- Notification -->
    <a href="#" class="qns-link" data-bs-toggle="modal" data-bs-target="#notificationModal">
      <i class="bi bi-bell-fill"></i>
      <span>Notification</span>
      <span class="badge bg-danger rounded-pill ms-auto">3</span>
    </a>

    <!-- Give Feedback -->
    <a href="#" class="qns-link" data-bs-toggle="modal" data-bs-target="#feedbackModal">
      <i class="bi bi-chat-heart-fill"></i>
      <span>Give Feedback</span>
    </a>

    <!-- Explore by Topic -->
    <div class="qns-section">
      <h6 class="qns-section-title"><i class="bi bi-compass-fill me-2"></i>Explore by Topic</h6>
      <div class="qns-topic-search">
        <div class="input-group input-group-sm">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" class="form-control" id="topicSearchInput" placeholder="Type to filter topics...">
        </div>
        <div class="qns-topic-results" id="topicResults" style="display:none;"></div>
        <div class="qns-topic-tags mt-2" id="topicTags">
          <span class="qns-tag" data-topic="prayer">🕌 Prayer</span>
          <span class="qns-tag" data-topic="patience">🤲 Patience</span>
          <span class="qns-tag" data-topic="charity">💰 Charity</span>
          <span class="qns-tag" data-topic="forgiveness">🕊️ Forgiveness</span>
          <span class="qns-tag" data-topic="justice">⚖️ Justice</span>
          <span class="qns-tag" data-topic="paradise">🌿 Paradise</span>
          <span class="qns-tag" data-topic="family">👨‍👩‍👧 Family</span>
          <span class="qns-tag" data-topic="knowledge">📖 Knowledge</span>
        </div>
      </div>
    </div>

    <!-- Dictionary -->
    <a href="/search/word" class="qns-link">
      <i class="bi bi-journal-text"></i>
      <span>Dictionary</span>
    </a>

    <!-- Settings -->
    <a href="#" class="qns-link" id="navSettingsLink">
      <i class="bi bi-gear-fill"></i>
      <span>Settings</span>
    </a>

    <!-- Help & Support -->
    <a href="#" class="qns-link" data-bs-toggle="modal" data-bs-target="#helpModal">
      <i class="bi bi-question-circle-fill"></i>
      <span>Help & Support</span>
    </a>
  </div>
</aside>
<div class="qns-overlay" id="quranNavOverlay"></div>

<!-- Feedback Modal -->
<div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white border-0">
        <h5 class="modal-title"><i class="bi bi-chat-heart-fill me-2"></i>Give Feedback</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-bold">Feedback Type</label>
          <select class="form-select" id="feedbackType">
            <option value="suggestion">💡 Suggestion</option>
            <option value="bug">🐛 Bug Report</option>
            <option value="correction">✅ Quran Correction</option>
            <option value="translation">📝 Translation Issue</option>
            <option value="feature">🚀 Feature Request</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Your Feedback</label>
          <textarea class="form-control" rows="4" id="feedbackText" placeholder="Share your thoughts..."></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Email (optional)</label>
          <input type="email" class="form-control" id="feedbackEmail" placeholder="your@email.com">
        </div>
      </div>
      <div class="modal-footer border-0">
        <button class="btn btn-success w-100 fw-bold" id="submitFeedback">
          <i class="bi bi-send me-1"></i>Submit Feedback
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Help & Support Modal -->
<div class="modal fade" id="helpModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-success text-white border-0">
        <h5 class="modal-title"><i class="bi bi-question-circle-fill me-2"></i>Help & Support</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="accordion" id="helpAccordion">
          <div class="accordion-item border-0 mb-2">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#help1">How to navigate surahs?</button></h2>
            <div id="help1" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
              <div class="accordion-body small">Use the Jump to Verse feature in the navigation menu, or browse all surahs from the Quran page.</div>
            </div>
          </div>
          <div class="accordion-item border-0 mb-2">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#help2">How to change translation?</button></h2>
            <div id="help2" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
              <div class="accordion-body small">Go to Settings > Translation & Tafsir to download and enable translations in your preferred language.</div>
            </div>
          </div>
          <div class="accordion-item border-0 mb-2">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#help3">How to use Word by Word?</button></h2>
            <div id="help3" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
              <div class="accordion-body small">Enable Word by Word in Settings > General. Click any Arabic word while reading to see its meaning.</div>
            </div>
          </div>
          <div class="accordion-item border-0 mb-2">
            <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#help4">How to change audio reciter?</button></h2>
            <div id="help4" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
              <div class="accordion-body small">Go to Settings > Audio Manager to select from 40+ reciters including Arabic, Urdu, English, and more.</div>
            </div>
          </div>
        </div>
        <hr>
        <div class="text-center">
          <p class="text-muted small mb-2">Need more help?</p>
          <a href="mailto:info@tazqianafs.com" class="btn btn-outline-success btn-sm"><i class="bi bi-envelope me-1"></i>Contact Support</a>
        </div>
      </div>
    </div>
  </div>
</div>
