<!-- Root Explorer Hero -->
<div class="root-hero">
    <div class="root-hero-bg"></div>
    <div class="root-hero-content">
        <div class="root-letters-display">
            <span class="root-letter" id="rootLettersDisplay"><%= root %></span>
        </div>
        <h2 class="root-transliteration" id="rootTransliteration"><%= transliteration || '' %></h2>
        <p class="root-meaning" id="rootMeaning">Loading meaning...</p>
        <div class="root-stats">
            <div class="root-stat">
                <i class="bi bi-hash"></i>
                <span id="rootTotalOccurrences">...</span>
                <small>Occurrences</small>
            </div>
            <div class="root-stat">
                <i class="bi bi-journal-text"></i>
                <span id="rootSurahCount">...</span>
                <small>Surahs</small>
            </div>
            <div class="root-stat">
                <i class="bi bi-collection"></i>
                <span id="rootDerivativeCount">...</span>
                <small>Derivatives</small>
            </div>
        </div>
    </div>
</div>

<!-- Sticky Search Bar -->
<div class="root-search-sticky" id="rootSearchSticky">
    <div class="root-search-inner d-flex align-items-center justify-content-center px-3" style="max-width: 800px; margin: 0 auto; gap: 15px;">
        <button onclick="history.back()" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; flex-shrink: 0;" title="Go Back">
            <i class="bi bi-arrow-left fs-5"></i>
        </button>
        <form action="/search/word" method="GET" class="root-search-form flex-grow-1" style="max-width: 600px;">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" name="q" placeholder="Search another root word..." value="<%= root %>" dir="rtl">
                <button class="btn btn-success" type="submit">Search</button>
            </div>
        </form>
        <div style="width: 38px; flex-shrink: 0;"></div> <!-- Spacer for precise centering -->
    </div>
</div>

<!-- Filters -->
<div class="root-filters card mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <div class="filter-group">
                <label class="filter-label"><i class="bi bi-funnel"></i> Filter:</label>
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="typeFilter" id="filterAll" value="all" checked>
                    <label class="btn btn-outline-success" for="filterAll">All</label>
                    <input type="radio" class="btn-check" name="typeFilter" id="filterMakki" value="Meccan">
                    <label class="btn btn-outline-success" for="filterMakki">Makki</label>
                    <input type="radio" class="btn-check" name="typeFilter" id="filterMadani" value="Medinan">
                    <label class="btn btn-outline-success" for="filterMadani">Madani</label>
                </div>
            </div>
            <div class="filter-group">
                <label class="filter-label">Sort:</label>
                <select class="form-select form-select-sm" id="sortSelect" style="width: auto;">
                    <option value="surah">By Surah</option>
                    <option value="frequency">By Frequency</option>
                </select>
            </div>
            <div class="filter-group ms-auto">
                <span class="badge bg-success" id="filteredCount">0 results</span>
            </div>
        </div>
    </div>
</div>

<!-- Derived Words Section -->
<div class="card mb-4 derivatives-card">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="bi bi-diagram-3-fill"></i> Derived Words</h5>
    </div>
    <div class="card-body">
        <div class="derivatives-grid" id="derivativesGrid">
            <div class="text-center text-muted py-3">
                <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                Loading derivatives...
            </div>
        </div>
    </div>
</div>

<!-- Results grouped by Surah -->
<div id="rootResultsContainer">
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Searching all 114 surahs...</p>
    </div>
</div>

<!-- Load More Button -->
<div class="text-center mt-4 mb-5" id="loadMoreContainer" style="display: none;">
    <button class="btn btn-outline-success btn-lg" id="loadMoreBtn">
        <i class="bi bi-arrow-down-circle"></i> Load More
    </button>
</div>

<style>
    /* Layout overrides for header-less view */
    body.page-root {
        padding-top: 0 !important;
    }

    /* Root Explorer Hero */
    .root-hero {
        position: relative;
        border-radius: 0 0 16px 16px;
        overflow: hidden;
        margin-bottom: 2rem;
        padding: 3rem 2rem;
        text-align: center;
        background: linear-gradient(135deg, #0d5c36 0%, #198754 40%, #20c997 100%);
        box-shadow: 0 8px 32px rgba(25, 135, 84, 0.3);
    }

    .root-hero-bg {
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.3;
    }

    .root-hero-content {
        position: relative;
        z-index: 1;
    }

    .root-letters-display {
        margin-bottom: 1rem;
    }

    .root-letter {
        font-family: 'Traditional Arabic', 'Scheherazade New', serif;
        font-size: 4rem;
        color: #fff;
        letter-spacing: 0.5rem;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        direction: rtl;
    }

    .root-transliteration {
        color: rgba(255,255,255,0.9);
        font-size: 1.3rem;
        font-weight: 400;
        margin-bottom: 0.5rem;
    }

    .root-meaning {
        color: rgba(255,255,255,0.8);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto 1.5rem;
    }

    .root-stats {
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .root-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        padding: 12px 24px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .root-stat i {
        color: #ffd700;
        font-size: 1.2rem;
    }

    .root-stat span {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .root-stat small {
        color: rgba(255,255,255,0.7);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Sticky Search */
    .root-search-sticky {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--bs-body-bg, #fff);
        padding: 12px 0;
        margin-bottom: 1rem;
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    [data-bs-theme="dark"] .root-search-sticky {
        border-bottom-color: rgba(255,255,255,0.1);
    }

    .root-search-form {
        margin: 0;
    }

    /* Filters */
    .filter-label {
        font-weight: 600;
        font-size: 0.85rem;
        margin-right: 8px;
        color: #555;
    }

    [data-bs-theme="dark"] .filter-label {
        color: #bbb;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Derivatives */
    .derivatives-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .derivative-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: linear-gradient(135deg, rgba(25,135,84,0.08), rgba(25,135,84,0.15));
        border: 1px solid rgba(25,135,84,0.2);
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        color: inherit;
    }

    .derivative-chip:hover {
        background: linear-gradient(135deg, rgba(25,135,84,0.15), rgba(25,135,84,0.25));
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(25,135,84,0.2);
        color: inherit;
    }

    .derivative-chip .arabic {
        font-family: 'Traditional Arabic', serif;
        font-size: 1.3rem;
        direction: rtl;
    }

    .derivative-chip .meaning {
        font-size: 0.8rem;
        color: #666;
    }

    .derivative-chip .count {
        font-size: 0.7rem;
        background: #198754;
        color: #fff;
        padding: 2px 8px;
        border-radius: 10px;
    }

    [data-bs-theme="dark"] .derivative-chip {
        background: linear-gradient(135deg, rgba(32,201,151,0.1), rgba(32,201,151,0.2));
        border-color: rgba(32,201,151,0.3);
    }

    [data-bs-theme="dark"] .derivative-chip .meaning {
        color: #aaa;
    }

    /* Result Groups */
    .surah-result-group {
        margin-bottom: 2rem;
        animation: fadeInUp 0.4s ease forwards;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .surah-group-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: linear-gradient(135deg, #198754, #20c997);
        color: #fff;
        border-radius: 10px 10px 0 0;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .surah-group-header:hover {
        filter: brightness(1.1);
    }

    .surah-group-header .surah-name {
        font-family: 'Traditional Arabic', serif;
        font-size: 1.3rem;
    }

    .surah-group-body {
        border: 1px solid rgba(25,135,84,0.2);
        border-top: none;
        border-radius: 0 0 10px 10px;
        overflow: hidden;
    }

    .root-ayah-card {
        padding: 16px;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        transition: background 0.2s ease;
    }

    .root-ayah-card:last-child {
        border-bottom: none;
    }

    .root-ayah-card:hover {
        background: rgba(25,135,84,0.03);
    }

    .root-ayah-arabic {
        font-family: var(--arabic-font, 'Traditional Arabic', serif);
        font-size: 1.5rem;
        line-height: 2.2;
        direction: rtl;
        text-align: right;
        margin-bottom: 8px;
    }

    .root-ayah-arabic mark {
        background-color: #198754;
        color: #ffffff !important;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: 700;
        box-shadow: 0 2px 8px rgba(25, 135, 84, 0.4);
    }

    .root-ayah-translation {
        font-size: 0.95rem;
        color: #666;
        line-height: 1.6;
    }

    .root-ayah-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
    }

    [data-bs-theme="dark"] .surah-group-body {
        border-color: rgba(32,201,151,0.2);
    }

    [data-bs-theme="dark"] .root-ayah-card {
        border-bottom-color: rgba(255,255,255,0.06);
    }

    [data-bs-theme="dark"] .root-ayah-card:hover {
        background: rgba(32,201,151,0.05);
    }

    [data-bs-theme="dark"] .root-ayah-translation {
        color: #aaa;
    }

    /* Mobile */
    @media (max-width: 576px) {
        .root-hero { padding: 2rem 1rem; }
        .root-letter { font-size: 3rem; }
        .root-stats { gap: 1rem; }
        .root-stat { padding: 8px 16px; }
        .root-stat span { font-size: 1.2rem; }
    }
</style>

<script>
(function() {
    const rootWord = '<%= root %>';
    const API_BASE = 'https://api.quran.com/api/v4';
    let allResults = [];
    let filteredResults = [];
    let displayedCount = 0;
    const BATCH_SIZE = 20;
    let derivativesMap = {};

    // Search for the root word across all surahs using our backend
    async function searchRootWord() {
        try {
            const response = await fetch(`/api/surahs/root-search/${encodeURIComponent(rootWord)}`);
            if (!response.ok) throw new Error('Search failed');
            const data = await response.json();

            if (data.success && data.data) {
                allResults = data.data.results || [];
                derivativesMap = data.data.derivatives || {};

                updateStats(allResults, derivativesMap);
                renderDerivatives(derivativesMap);
                filteredResults = [...allResults];
                displayedCount = 0;
                renderResults();
            }
        } catch (error) {
            console.error('Root search error:', error);
            document.getElementById('rootResultsContainer').innerHTML = `
                <div class="alert alert-warning text-center">
                    <i class="bi bi-exclamation-triangle"></i>
                    Could not search for root word. Please try again.
                </div>`;
        }
    }

    function updateStats(results, derivatives) {
        document.getElementById('rootTotalOccurrences').textContent = results.length;
        const surahSet = new Set(results.map(r => r.surahId));
        document.getElementById('rootSurahCount').textContent = surahSet.size;
        document.getElementById('rootDerivativeCount').textContent = Object.keys(derivatives).length;
        document.getElementById('rootMeaning').textContent =
            results.length > 0 ? `Found in ${surahSet.size} surahs across the Quran` : 'No occurrences found';
    }

    function renderDerivatives(derivatives) {
        const grid = document.getElementById('derivativesGrid');
        if (Object.keys(derivatives).length === 0) {
            grid.innerHTML = '<p class="text-muted mb-0">No derivatives found</p>';
            return;
        }

        grid.innerHTML = Object.entries(derivatives)
            .sort((a, b) => b[1] - a[1])
            .map(([word, count]) => `
                <a href="/search/word?q=${encodeURIComponent(word)}" class="derivative-chip">
                    <span class="arabic">${word}</span>
                    <span class="count">${count}×</span>
                </a>
            `).join('');
    }

    function renderResults() {
        const container = document.getElementById('rootResultsContainer');
        const batch = filteredResults.slice(displayedCount, displayedCount + BATCH_SIZE);

        if (displayedCount === 0) {
            container.innerHTML = '';
        }

        if (filteredResults.length === 0) {
            container.innerHTML = `
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> No results found for this filter.
                </div>`;
            document.getElementById('loadMoreContainer').style.display = 'none';
            return;
        }

        // Group batch by surah
        const grouped = {};
        batch.forEach(result => {
            if (!grouped[result.surahId]) {
                grouped[result.surahId] = {
                    surahName: result.surahName,
                    surahTransliteration: result.surahTransliteration,
                    surahBanglish: result.surahBanglish,
                    surahId: result.surahId,
                    ayahs: []
                };
            }
            grouped[result.surahId].ayahs.push(result);
        });

        Object.values(grouped).forEach(group => {
            // Check if this surah group already exists
            let existingGroup = container.querySelector(`[data-surah-id="${group.surahId}"]`);
            if (existingGroup) {
                const body = existingGroup.querySelector('.surah-group-body');
                group.ayahs.forEach(ayah => {
                    body.innerHTML += renderAyahCard(ayah, group.surahId);
                });
            } else {
                const groupEl = document.createElement('div');
                groupEl.className = 'surah-result-group';
                groupEl.dataset.surahId = group.surahId;
                groupEl.innerHTML = `
                    <div class="surah-group-header" onclick="this.nextElementSibling.classList.toggle('d-none')">
                        <div>
                            <span class="surah-name">${group.surahName}</span>
                            <span class="ms-2">${group.surahTransliteration}</span>
                        </div>
                        <span class="badge bg-light text-dark">${group.ayahs.length} ayahs</span>
                    </div>
                    <div class="surah-group-body">
                        ${group.ayahs.map(a => renderAyahCard(a, group.surahId)).join('')}
                    </div>
                `;
                container.appendChild(groupEl);
            }
        });

        displayedCount += batch.length;
        document.getElementById('filteredCount').textContent = `${filteredResults.length} results`;

        // Show/hide load more
        const loadMoreContainer = document.getElementById('loadMoreContainer');
        loadMoreContainer.style.display = displayedCount < filteredResults.length ? 'block' : 'none';
    }

    function renderAyahCard(ayah, surahId) {
        const defaultTranslation = Object.values(ayah.translations || {})[0] || '';
        return `
            <div class="root-ayah-card">
                <div class="root-ayah-arabic">${ayah.highlightedText || ayah.arabicText}</div>
                <div class="root-ayah-translation">${defaultTranslation}</div>
                <div class="root-ayah-meta">
                    <a href="/surah/${surahId}#ayah-${ayah.ayahNumber}" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-book"></i> ${ayah.ayahNumber}
                    </a>
                    <span class="badge bg-secondary">${ayah.surahTransliteration} ${ayah.ayahNumber}</span>
                </div>
            </div>`;
    }

    // Filters
    document.querySelectorAll('input[name="typeFilter"]').forEach(radio => {
        radio.addEventListener('change', () => {
            const filter = document.querySelector('input[name="typeFilter"]:checked').value;
            applyFilters(filter);
        });
    });

    function applyFilters(typeFilter) {
        filteredResults = allResults.filter(r => {
            if (typeFilter !== 'all' && r.surahType !== typeFilter) return false;
            return true;
        });
        displayedCount = 0;
        renderResults();
    }

    // Load more
    document.getElementById('loadMoreBtn').addEventListener('click', renderResults);

    // Infinite scroll
    let scrollThrottle = false;
    window.addEventListener('scroll', () => {
        if (scrollThrottle) return;
        scrollThrottle = true;
        setTimeout(() => { scrollThrottle = false; }, 200);

        const loadMore = document.getElementById('loadMoreContainer');
        if (loadMore.style.display !== 'none' && loadMore.getBoundingClientRect().top < window.innerHeight + 200) {
            renderResults();
        }
    });

    // Start search
    searchRootWord();
})();
</script>
