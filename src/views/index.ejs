<script>
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });

    // Auto-scroll the hero ayah list
    const ayahList = document.getElementById('heroAyahList');
    if (ayahList) {
        let isHovered = false;
        
        ayahList.addEventListener('mouseenter', () => isHovered = true);
        ayahList.addEventListener('mouseleave', () => isHovered = false);

        setInterval(() => {
            if (!isHovered) {
                ayahList.scrollTop += 1;
                if (ayahList.scrollTop + ayahList.clientHeight >= ayahList.scrollHeight - 1) {
                    setTimeout(() => {
                        ayahList.scrollTo({ top: 0, behavior: 'smooth' });
                    }, 2000);
                }
            }
        }, 50);
    }
</script>
